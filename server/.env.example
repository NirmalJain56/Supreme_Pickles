# Supreme Pickles Server — Environment Variables

PORT=5000
NODE_ENV=development

# MongoDB connection string (local or Atlas)
MONGO_URI=mongodb://localhost:27017/supreme_pickles

# JWT Secret (change to a long random string in production)
JWT_SECRET=supreme_pickles_super_secret_jwt_key_2024
JWT_EXPIRE=30d

# Razorpay Test Keys (get from https://dashboard.razorpay.com)
RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_SECRET

# Client URL for CORS
CLIENT_URL=http://localhost:5173
